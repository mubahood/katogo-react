# Katogo React — Environment Variables
# Copy this file to .env and fill in your values

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=https://katogo.ugnews24.info

# Google OAuth Client ID (from Google Cloud Console)
# Required for "Sign in with Google" on login/register pages
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Sentry DSN for error tracking (get from sentry.io)
VITE_SENTRY_DSN=your_sentry_dsn_here

# App version (bumped on release)
VITE_APP_VERSION=3.0.0

# Set to "true" to enable analytics tracking
VITE_ENABLE_ANALYTICS=true
